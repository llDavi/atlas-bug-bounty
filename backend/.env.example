# Copy this file to .env and fill in your own credentials.
# .env is gitignored, never commit real tokens.

# HackerOne: Settings -> API Token (https://hackerone.com/settings/api_token/edit)
HACKERONE_USERNAME=
HACKERONE_API_TOKEN=

# Intigriti: Personal Access Token from your researcher account settings
INTIGRITI_API_TOKEN=

# Clerk: Dashboard -> API Keys -> Secret key
CLERK_SECRET_KEY=

# Any random long string — protects GET /api/admin/* endpoints (use as a Bearer token)
ADMIN_TOKEN=

# Stripe: Dashboard -> Developers -> API keys (use the test mode keys while developing)
STRIPE_SECRET_KEY=
# Stripe: Dashboard -> Developers -> Webhooks (or the `stripe listen` CLI output for local dev)
STRIPE_WEBHOOK_SECRET=
# Stripe: Dashboard -> Product catalog -> Atlas Pro -> copy each recurring Price's id (price_...)
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Where Stripe Checkout redirects back to after payment (your frontend dev/prod URL)
FRONTEND_URL=http://localhost:5173
